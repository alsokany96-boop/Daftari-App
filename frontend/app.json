{
  "expo": {
    "name": "frontend",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergent.billkeeper.jm9bck",
      "infoPlist": {
        "NSCameraUsageDescription": "التقط صور الفواتير مع كل عملية",
        "NSPhotoLibraryUsageDescription": "أرفق صور الفواتير من معرضك"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emergent.billkeeper.jm9bck",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "name": "دفتري",
      "shortName": "دفتري",
      "display": "standalone",
      "themeColor": "#EF4444",
      "backgroundColor": "#F8FAFC",
      "orientation": "portrait",
      "lang": "ar",
      "dir": "rtl"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "أرفق صور الفواتير من معرضك",
          "cameraPermission": "التقط صور الفواتير مع كل عملية"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}